#!/usr/bin/env bash
set -e
set +u

source /opt/ros/${ROS_DISTRO}/setup.bash
source /home/.base/bin/activate

rm -f /home/.base/bin/register-python-argcomplete 2>/dev/null || true

WS=/ros2_ws
DEFAULT_SKIP_PKGS=("livox_ros_driver2")

clean_pkgs() {
  rm -rf "${WS}/log" 2>/dev/null || true
  for p in "$@"; do
    rm -rf "${WS}/build/${p}" "${WS}/install/${p}" 2>/dev/null || true
  done
}

clean_all() {
  rm -rf "${WS}/build" "${WS}/install" "${WS}/log" 2>/dev/null || true
}

if [ "${CLEAN:-0}" = "1" ]; then
  clean_all
fi

has_token() {
  local needle="$1"; shift
  for x in "$@"; do
    if [ "$x" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

if [ "$#" -eq 0 ]; then
  clean_pkgs unitree_api unitree_go unitree_hg unitree_sdk2py

  if [ "${BUILD_LIVOX:-0}" = "1" ]; then
    clean_pkgs livox_ros_driver2
    /home/.base/bin/python3 -m colcon build --symlink-install --executor parallel --parallel-workers 4
  else
    clean_pkgs livox_ros_driver2
    /home/.base/bin/python3 -m colcon build --symlink-install --executor parallel --parallel-workers 4 --packages-skip "${DEFAULT_SKIP_PKGS[@]}"
  fi

  exit 0
fi

if [ "$1" = "all" ]; then
  shift
  clean_pkgs unitree_api unitree_go unitree_hg unitree_sdk2py livox_ros_driver2
  /home/.base/bin/python3 -m colcon build --symlink-install --executor parallel --parallel-workers 4
  exit 0
fi

clean_pkgs "$@"
 /home/.base/bin/python3 -m colcon build --symlink-install --executor parallel --parallel-workers 4 --packages-select "$@"
